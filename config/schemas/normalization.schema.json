{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "F5 XC API Normalization Configuration",
  "description": "Schema for normalization configuration controlling spec cleaning and standardization",
  "type": "object",
  "properties": {
    "schema_fixes": {
      "type": "object",
      "description": "Schema-level fixes and corrections"
    },
    "type_fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string"
          },
          "replacement": {
            "type": "string"
          }
        }
      }
    },
    "cleanup_patterns": {
      "type": "object",
      "description": "Patterns for cleaning up specifications"
    }
  }
}
