{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "F5 XC Operation Descriptions Configuration",
  "description": "Schema for operation descriptions with DRY-compliant 3-tier descriptions",
  "type": "object",
  "required": ["resources", "patterns", "method_fallbacks"],
  "properties": {
    "resources": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["short", "medium", "long"],
          "properties": {
            "short": {
              "type": "string",
              "minLength": 1,
              "maxLength": 60
            },
            "medium": {
              "type": "string",
              "minLength": 1,
              "maxLength": 150
            },
            "long": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resource_pattern", "short", "medium", "long"],
        "properties": {
          "resource_pattern": {
            "type": "string",
            "minLength": 1
          },
          "short": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          },
          "medium": {
            "type": "string",
            "minLength": 1,
            "maxLength": 150
          },
          "long": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    },
    "method_fallbacks": {
      "type": "object",
      "patternProperties": {
        "^(GET|POST|PUT|DELETE|PATCH)$": {
          "type": "object",
          "required": ["short", "medium", "long"],
          "properties": {
            "short": {
              "type": "string",
              "minLength": 1,
              "maxLength": 60
            },
            "medium": {
              "type": "string",
              "minLength": 1,
              "maxLength": 150
            },
            "long": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    }
  }
}
