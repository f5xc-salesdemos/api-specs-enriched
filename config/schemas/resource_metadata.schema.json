{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "F5 XC Resource Metadata Configuration",
  "description": "Schema for per-resource metadata definitions",
  "type": "object",
  "required": ["resources"],
  "properties": {
    "resources": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["description", "description_short"],
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "description_short": {
              "type": "string",
              "minLength": 1,
              "maxLength": 60
            },
            "tier": {
              "type": "string",
              "enum": ["Free", "Standard", "Advanced", "Enterprise"]
            },
            "icon": {
              "type": "string",
              "maxLength": 4
            },
            "category": {
              "type": "string",
              "minLength": 1
            },
            "supports_logs": {
              "type": "boolean"
            },
            "supports_metrics": {
              "type": "boolean"
            },
            "dependencies": {
              "type": "object",
              "properties": {
                "required": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "optional": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "relationship_hints": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
