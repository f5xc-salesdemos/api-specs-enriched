{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "F5 XC Server Variables Configuration",
  "description": "Schema for OpenAPI server variables configuration",
  "type": "object",
  "required": ["version", "server", "variables"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Configuration version"
    },
    "server": {
      "type": "object",
      "required": ["url_template", "description"],
      "properties": {
        "url_template": {
          "type": "string",
          "description": "URL template with variable placeholders"
        },
        "description": {
          "type": "string",
          "description": "Server description"
        }
      }
    },
    "variables": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["default", "description"],
          "properties": {
            "default": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "enum": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "env_var": {
              "type": "string",
              "pattern": "^F5XC_[A-Z_]+$"
            },
            "examples": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "notes": {
              "type": "string"
            },
            "naming_pattern": {
              "type": "string"
            }
          }
        }
      }
    },
    "github_branch_mapping": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "patterns": {
          "type": "object"
        }
      }
    },
    "documentation": {
      "type": "object",
      "properties": {
        "multi_environment_strategy": {
          "type": "string"
        },
        "extensibility_notes": {
          "type": "string"
        }
      }
    }
  }
}
